{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tiny Llama",
  "identifier": "dev.tinyllama.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tiny Llama",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/**", "$HOME/**"]
      },
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
