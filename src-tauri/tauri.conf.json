{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spacebar Editor",
  "identifier": "dev.spacebar.editor",
  "version": "0.1.17",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:14200",
    "beforeBuildCommand": "pnpm build:skip-tests",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../scripts/spacebar-cli.sh"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI coding assistant",
    "longDescription": "A privacy-first desktop AI coding assistant. Run local models via Ollama or llama.cpp, or connect your own cloud API key. Your code never leaves your machine.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Spacebar Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' tauri: asset:",
        "style-src": "'self' 'unsafe-inline' tauri: asset:",
        "img-src": "'self' data: tauri: asset: blob: http://localhost:* http://127.0.0.1:*",
        "font-src": "'self' tauri: asset: data:",
        "connect-src": "'self' tauri: asset: https://api.anthropic.com https://api.deepseek.com https://api.z.ai https://api.moonshot.ai https://api.github.com https://ping.spacebar.dev http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
        "media-src": "'self' tauri: asset: blob:",
        "worker-src": "'self' blob:",
        "frame-src": "'self' tauri: asset: http://localhost:* http://127.0.0.1:*"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/**", "$HOME/**"]
      },
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNURFNDE1QjhGMDI1OApSV1JZQW85YlFkN0ZETHEzbjI2NFVIK0NJZEFuVUtUOVFVeUtERU9WZEc0cFl6eWVxMVYyK2ZQRwo=",
      "endpoints": [
        "https://github.com/Nxe5/spacebar-editor/releases/latest/download/latest.json"
      ]
    }
  }
}
