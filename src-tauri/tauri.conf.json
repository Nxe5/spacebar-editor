{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spacebar Editor",
  "identifier": "dev.spacebar.editor",
  "version": "0.1.2",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:14200",
    "beforeBuildCommand": "pnpm build:skip-tests",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI coding assistant",
    "longDescription": "A privacy-first desktop AI coding assistant. Run local models via Ollama or llama.cpp, or connect your own cloud API key. Your code never leaves your machine.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Spacebar Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' tauri: asset:",
        "style-src": "'self' 'unsafe-inline' tauri: asset:",
        "img-src": "'self' data: tauri: asset: blob:",
        "font-src": "'self' tauri: asset: data:",
        "connect-src": "'self' tauri: asset: https://api.anthropic.com https://api.deepseek.com http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
        "media-src": "'self' tauri: asset: blob:",
        "worker-src": "'self' blob:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/**", "$HOME/**"]
      },
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
