{
  "name": "spacebar-editor",
  "private": true,
  "version": "0.1.15",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/free-dev-port.mjs && vite",
    "dev:desktop": "node scripts/tauri-dev.mjs dev",
    "build": "pnpm run test && vite build",
    "build:skip-tests": "vite build",
    "preview": "vite preview",
    "tauri": "node scripts/tauri-dev.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ollama": "RUN_OLLAMA_TESTS=1 vitest run tests/integration/ollama.test.ts",
    "test:ollama-tools": "RUN_OLLAMA_TESTS=1 vitest run tests/integration/ollamaToolCalling.test.ts",
    "test:llamacpp": "RUN_LLAMACPP_TESTS=1 vitest run tests/integration/llamacpp.test.ts",
    "test:deepseek": "RUN_DEEPSEEK_TESTS=1 vitest run tests/integration/deepseek.test.ts",
    "test:coverage": "vitest run --coverage",
    "release": "node scripts/release.mjs",
    "install-cli": "node scripts/install-cli.mjs",
    "update-homebrew-cask": "node scripts/update-homebrew-cask.mjs",
    "sync-homebrew-tap": "node scripts/sync-homebrew-tap.mjs",
    "publish-homebrew-tap": "bash scripts/publish-homebrew-tap.sh",
    "spacebar": "bash scripts/spacebar-cli.sh",
    "sync-icons": "node scripts/sync-vscode-icons.mjs",
    "eval": "tsx tests/llm/harness.ts",
    "eval:report": "tsx tests/llm/scripts/open-latest-report.ts",
    "eval:gemma": "EVAL_PROFILE=gemma-12b tsx tests/llm/harness.ts",
    "eval:gemma-smoke": "EVAL_PROFILE=gemma-12b tsx tests/llm/harness.ts -- --smoke",
    "eval:gemma-tools": "EVAL_PROFILE=gemma-12b tsx tests/llm/harness.ts -- --suite 16-gemma-tool-calling",
    "eval:gemma-build": "EVAL_PROFILE=gemma-12b tsx tests/llm/harness.ts -- --suite 19-gemma-project-build",
    "eval:gemma-landing": "EVAL_PROFILE=gemma-12b tsx tests/llm/harness.ts -- --test build-landing-01"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.0.0",
    "clsx": "^2.1.1",
    "playwright-core": "^1.60.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.0",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.1.0",
    "@codemirror/lang-rust": "^6.0.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.11.0",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.3",
    "@lucide/svelte": "^1.16.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "bits-ui": "^2.18.1",
    "codemirror": "^6.0.0",
    "codemirror-lang-svelte": "^2.1.0",
    "gpt-tokenizer": "^2.5.0",
    "marked": "^18.0.4",
    "mode-watcher": "^1.1.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.3"
  }
}
