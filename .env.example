# Optional: dev server port (must match src-tauri/tauri.conf.json devUrl if overridden)
# VITE_PORT=14200

# Optional dev API keys (loaded in `pnpm dev` when Settings fields are empty).
# Supported names: DEEPSEEK_API_KEY or deepseek_api_key, ANTHROPIC_API_KEY or anthropic_api_key,
# GLM_API_KEY or ZAI_API_KEY, KIMI_API_KEY or MOONSHOT_API_KEY
# DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GLM_API_KEY=...
# KIMI_API_KEY=sk-...
#
# Integration tests (never commit real keys):
#   pnpm test:deepseek   # needs RUN_DEEPSEEK_TESTS=1 and key in .env
#
# Do not put production secrets in env vars wired into Vite unless you intend them for the bundle.
